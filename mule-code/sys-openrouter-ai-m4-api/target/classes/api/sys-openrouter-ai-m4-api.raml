#%RAML 1.0
title: sys-openrouter-ai-m4-api
version: v1
description: system api to connect to ai services

/ai:
  post:
    body:
      application/json:
        example:
          {
             "points" : "[[79.990694,23.180912],[79.912341,23.06697],[79.763084,22.83259],[79.572757,22.455285],[79.54351,22.086997] ]"
          }
    responses:
      200:
        description: successful 
        body:
          application/json:
            example:
              !include examples/200ResponseExample.raml
      402:
        description: Payment required
        body:
          application/json:
            example:
              !include examples/402ResponseExample.raml
